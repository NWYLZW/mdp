{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "mdp:vscode-extension build",
      "type": "shell",
      "command": "pnpm",
      "args": [
        "--filter",
        "@modeldriveprotocol/vscode-extension",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": "$tsc"
    }
  ]
}
